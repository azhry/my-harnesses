{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.harnesses/agent-spec-ops/local-tasks.schema.json",
  "title": "Agent Spec Ops Local Task List",
  "type": "object",
  "required": ["provider", "delivery_id", "updated_at", "tasks"],
  "additionalProperties": false,
  "properties": {
    "provider": {
      "type": "object",
      "required": ["mode", "external_provider", "sync_status", "last_synced_at", "evidence"],
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["local", "external", "hybrid"] },
        "external_provider": { "type": "string" },
        "sync_status": { "enum": ["local_only", "linked", "synced", "blocked"] },
        "last_synced_at": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } }
      }
    },
    "delivery_id": { "type": "string" },
    "updated_at": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "role",
          "status",
          "description",
          "depends_on",
          "acceptance_criteria",
          "evidence",
          "external",
          "created_at",
          "updated_at"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "role": { "type": "string" },
          "status": {
            "enum": [
              "planned",
              "active",
              "implemented",
              "testing",
              "failed",
              "verified",
              "blocked",
              "waived",
              "not_applicable"
            ]
          },
          "description": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "external": {
            "type": "object",
            "required": ["provider", "id", "url", "sync_status"],
            "additionalProperties": false,
            "properties": {
              "provider": { "type": "string" },
              "id": { "type": "string" },
              "url": { "type": "string" },
              "sync_status": { "enum": ["local_only", "linked", "synced", "blocked"] }
            }
          },
          "created_at": { "type": "string" },
          "updated_at": { "type": "string" }
        }
      }
    }
  }
}
