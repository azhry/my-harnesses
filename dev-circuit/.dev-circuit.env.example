LINEAR_API_KEY=
DEVCIRCUIT_STATE_KEY=replace-with-at-least-32-random-characters
# Optional external agent adapters. Each executable receives a context JSON path
# and must print the fresh external agent/session id on its final stdout line.
DEVCIRCUIT_PLANNER_ADAPTER=
DEVCIRCUIT_AGENT_ADAPTER=
# Required trusted container/VM runner. Interface:
# runner --cwd <path> --home <ephemeral-home> -- <executable> [args...]
# runner --self-test
DEVCIRCUIT_SANDBOX_RUNNER=
# Human-approved digest of the exact runner executable (shasum -a 256 <runner>).
DEVCIRCUIT_SANDBOX_RUNNER_SHA256=
# Optional explicit worker variables, comma-separated. Controller credentials are never eligible.
DEVCIRCUIT_WORKER_ENV_ALLOW=
# GitHub login of the dedicated App/bot allowed by the ruleset to publish devcircuit/gate.
DEVCIRCUIT_GATE_ACTOR=
# Optional comma-separated check-run names required on the merge commit.
DEVCIRCUIT_POST_MERGE_CHECKS=
