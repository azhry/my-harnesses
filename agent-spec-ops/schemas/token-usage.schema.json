{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.harnesses/agent-spec-ops/token-usage-row.schema.json",
  "title": "Agent Spec Ops Token Usage CSV Row",
  "type": "object",
  "required": [
    "at",
    "delivery_id",
    "scope",
    "role",
    "task_id",
    "eval_id",
    "loop",
    "provider",
    "model",
    "input_tokens",
    "output_tokens",
    "cached_input_tokens",
    "reasoning_tokens",
    "total_tokens",
    "input_cost_usd",
    "output_cost_usd",
    "cached_input_cost_usd",
    "reasoning_cost_usd",
    "total_cost_usd",
    "currency",
    "cost_basis",
    "source",
    "evidence",
    "notes"
  ],
  "additionalProperties": false,
  "properties": {
    "at": { "type": "string" },
    "delivery_id": { "type": "string" },
    "scope": { "enum": ["run", "task", "eval", "role", "tool"] },
    "role": { "type": "string" },
    "task_id": { "type": "string" },
    "eval_id": { "type": "string" },
    "loop": { "type": "string" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "input_tokens": { "type": ["integer", "string"], "minimum": 0 },
    "output_tokens": { "type": ["integer", "string"], "minimum": 0 },
    "cached_input_tokens": { "type": ["integer", "string"], "minimum": 0 },
    "reasoning_tokens": { "type": ["integer", "string"], "minimum": 0 },
    "total_tokens": { "type": ["integer", "string"], "minimum": 0 },
    "input_cost_usd": { "type": ["number", "string"], "minimum": 0 },
    "output_cost_usd": { "type": ["number", "string"], "minimum": 0 },
    "cached_input_cost_usd": { "type": ["number", "string"], "minimum": 0 },
    "reasoning_cost_usd": { "type": ["number", "string"], "minimum": 0 },
    "total_cost_usd": { "type": ["number", "string"], "minimum": 0 },
    "currency": { "type": "string" },
    "cost_basis": { "enum": ["actual", "estimated", "unknown"] },
    "source": { "type": "string" },
    "evidence": { "type": ["string", "array"], "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
