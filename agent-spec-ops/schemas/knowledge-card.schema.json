{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.harnesses/agent-spec-ops/knowledge-card.schema.json",
  "title": "Agent Spec Ops Knowledge Card",
  "type": "object",
  "required": [
    "id",
    "kind",
    "status",
    "statement",
    "rationale",
    "applies_to",
    "confidence",
    "source_event_ids",
    "evidence",
    "usage_count",
    "created_at",
    "updated_at",
    "promoted_at",
    "deprecated_at",
    "supersedes",
    "superseded_by"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "kind": {
      "enum": [
        "product_rule",
        "design_rule",
        "system_rule",
        "repository_pattern",
        "verification_pattern",
        "process_rule",
        "decision",
        "risk",
        "anti_pattern"
      ]
    },
    "status": {
      "enum": ["observed", "candidate", "promoted", "active", "deprecated"]
    },
    "statement": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string" },
    "applies_to": {
      "type": "object",
      "required": ["roles", "components", "repos", "services", "tasks", "tags"],
      "additionalProperties": false,
      "properties": {
        "roles": { "type": "array", "items": { "type": "string" } },
        "components": { "type": "array", "items": { "type": "string" } },
        "repos": { "type": "array", "items": { "type": "string" } },
        "services": { "type": "array", "items": { "type": "string" } },
        "tasks": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confidence": { "enum": ["low", "medium", "high", "unknown"] },
    "source_event_ids": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "usage_count": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "promoted_at": { "type": "string" },
    "deprecated_at": { "type": "string" },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string" }
  }
}
